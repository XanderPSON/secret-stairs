{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "ignoreCommand": "if [ \"$VERCEL_GIT_COMMIT_REF\" = \"public-deploy\" ]; then exit 1; else exit 0; fi",
  "installCommand": "cd ../.. && yarn install",
  "buildCommand": "cd ../.. && yarn workspace @app/secret-phrase build",
  "outputDirectory": ".next",
  "framework": "nextjs"
}
