# Secret phrase displayed in the stairwell — case-insensitive match
SECRET_OFFICE_PHRASE="your secret phrase here"

# CDP Paymaster URL from portal.cdp.coinbase.com > Onchain Tools > Paymaster.
# Server-side only — the browser hits /api/paymaster which forwards to this URL,
# keeping the CDP API key out of the client bundle.
PAYMASTER_URL="https://api.developer.coinbase.com/rpc/v1/base-sepolia/YOUR_CDP_API_KEY"

# WelcomeNFT contract address on Base Sepolia (deploy first, then fill this in)
NEXT_PUBLIC_CONTRACT_ADDRESS="0x0000000000000000000000000000000000000000"

# CDP SDK credentials — obtain from https://portal.cdp.coinbase.com/access/api
# Used by scripts/faucet.ts for programmatic testnet funding
CDP_API_KEY_ID="YOUR_CDP_API_KEY_ID"
CDP_API_KEY_SECRET="YOUR_CDP_API_KEY_SECRET"
CDP_WALLET_SECRET="YOUR_CDP_WALLET_SECRET"

# Optional: private RPC URLs for the admin dashboard (improves rate-limits and
# reliability vs the default public viem RPCs). Leave unset to use defaults.
NEXT_PUBLIC_BASE_SEPOLIA_RPC_URL=""
NEXT_PUBLIC_BASE_RPC_URL=""

# Required to enable Basename / ENS resolution in the admin dashboard.
# ENSIP-19 resolution starts on Ethereum mainnet via the Universal Resolver
# and crosses to Base via state proofs — public mainnet RPCs will rate-limit
# or refuse the call. Use a private endpoint (e.g., CDP, Alchemy, Infura).
# If unset, the dashboard works fine but minter addresses stay truncated.
# CDP example: https://api.developer.coinbase.com/rpc/v1/ethereum-mainnet/<KEY>
NEXT_PUBLIC_ETH_MAINNET_RPC_URL=""
